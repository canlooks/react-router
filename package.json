{
  "name": "@canlooks/react-router",
  "version": "0.0.12",
  "author": "C.CanLiang <canlooks@gmail.com>",
  "description": "React router manager",
  "keywords": [
    "react",
    "router",
    "react-router"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/canlooks/c_reactive"
  },
  "homepage": "https://gitee.com/canlooks/c_reactive",
  "bugs": {
    "url": "https://gitee.com/canlooks/c_reactive/issues",
    "email": "canlooks@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "build": "tscup",
    "clean": "tscup clean",
    "test": "vite -c test/vite.config.mts",
    "test:unit": "ts-node test/unitTest.ts"
  },
  "dependencies": {
    "path-browserify": "^1.0.1",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@canlooks/tscup": "^0.0.6",
    "@types/node": "^22.8.4",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
