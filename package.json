{
  "name": "@canlooks/react-router",
  "version": "0.0.13",
  "author": "C.CanLiang <canlooks@gmail.com>",
  "description": "React router manager",
  "keywords": [
    "react",
    "router",
    "react-router"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/canlooks/c_reactive"
  },
  "homepage": "https://gitee.com/canlooks/c_reactive",
  "bugs": {
    "url": "https://gitee.com/canlooks/c_reactive/issues",
    "email": "canlooks@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "clean": "npx shx rm -rf dist",
    "build": "npm run clean && tscup",
    "test": "vite -c test/vite.config.mts",
    "test:unit": "ts-node test/unitTest.ts"
  },
  "dependencies": {
    "path-browserify": "^1.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@canlooks/tscup": "^0.1.2",
    "@types/node": "^22.10.2",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
